{
  "require-dev": {
    "squizlabs/php_codesniffer": "^3.7",
    "wp-coding-standards/wpcs": "^3.0",
    "vimeo/psalm": "^6.0",
    "rector/rector": "^2.1",
    "php-stubs/wordpress-stubs": "^6.4"
  },
  "scripts": {
    "lint": "composer lint:phpcs && composer lint:psalm && composer lint:rector",
    "lint:phpcs": "phpcs --standard=config/lint/phpcs.xml --extensions=php --ignore=vendor --error-severity=1 --warning-severity=0 wp-content/themes",
    "lint:psalm": "psalm --config=config/lint/psalm.xml --no-cache --threads=1",
    "lint:rector": "vendor/bin/rector process --dry-run --config=config/lint/rector.php",
    "fix": "phpcbf --standard=config/lint/phpcs.xml --extensions=php --ignore=vendor wp-content/themes && vendor/bin/rector process --config=config/lint/rector.php"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
