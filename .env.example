WORDPRESS_PORT=8000

DB_HOST=mysql
DB_PORT=3306
DB_USER=wordpress
DB_PASSWORD=wordpress
DB_NAME=wp-app
DB_ROOT_PASSWORD=wordpress

PHPMYADMIN_PORT=8080

ENVIRONMENT=development  # или production для продакшена

# Все урлы указываем без слэша / в конце адреса, иначе импорт БД не сработает
URL_LOCAL=http://localhost:8000
URL_DEV=https://test.site
URL_PROD=https://prod.site

# Не меняем для корректной работы CI/CD
THEME_DIRECTORY=child-theme

ADMIN_USER=dev
ADMIN_PASSWORD=root
ADMIN_EMAIL=admin@email.com
